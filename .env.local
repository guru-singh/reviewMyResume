# Basic configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Enable Gemini / Claude calls when true. Set to "false" to use the stub data flow.
ENABLE_REAL_GEMINI=false

# Supabase credentials (fill these in before running)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM configuration
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_API_VERSION=v1beta
GEMINI_MODEL=models/gemini-1.5-pro
GEMINI_INPUT_LIMIT=700000
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest
